{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Python Farming",
  "version": "0.1.0",
  "identifier": "com.pythonfarming.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Python Farming",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 680,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "shortDescription": "Başlangıçtan uzmanlığa Python öğrenme masaüstü uygulaması.",
    "longDescription": "Python Farming; dersler, alıştırmalar, hata ayıklama görevleri ve proje laboratuvarlarıyla Python öğretir.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
