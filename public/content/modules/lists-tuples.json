      "task": {
        "title": "İlk ve son ürünü seç",
        "instructions": [
          "urunler adlı üç elemanlı bir liste oluştur.",
          "ilk_urun değişkenine ilk elemanı indeksle.",
          "son_urun değişkenine negatif indeksle son elemanı al.",
          "İki ürünü belirtilen biçimde yazdır."
        ],
        "requirements": [
          "urunler gerçek bir list olmalı.",
          "En az iki Subscript yapısı kullanılmalı.",
          "Son elemana -1 indeksiyle erişilmeli."
        ],
        "sampleOutput": "İlk: Defter\nSon: Çanta",
