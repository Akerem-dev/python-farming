        "stdinPlaceholder": "Bu görev dışarıdan girdi istemiyor.",
        "defaultStdin": ""
      },
      "editor": {
        "filename": "main.py",
        "starterCode": "urunler = [\"Defter\", \"Kalem\", \"Çanta\"]\n\nilk_urun = \"\"\nson_urun = \"\"\n\nprint(f\"İlk: {ilk_urun}\")\nprint(f\"Son: {son_urun}\")"
      },
      "hints": [
        { "title": "İlk indeks sıfırdır", "body": "İlk eleman urunler[0] ile alınır." },
        { "title": "Negatif indeksler sondan başlar", "body": "Son eleman için urunler[-1] kullan." },
        { "title": "Atamaları tamamla", "body": "ilk_urun = urunler[0] ve son_urun = urunler[-1] yaz." }
      ],
      "validation": {
        "id": "beginner.lists-tuples.indexing",
        "title": "İlk ve son ürünü seç",
        "xpReward": 45,
        "timeoutMs": 4000,
        "checks": [
          { "id": "products-list", "kind": "variable_type", "name": "urunler", "expectedType": "list", "label": "urunler bir liste", "visibility": "visible" },
