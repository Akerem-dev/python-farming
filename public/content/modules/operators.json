      "id": "beginner.operators.arithmetic",
      "moduleId": "operators",
      "order": 1,
      "title": "Dört işlem operatörleri",
      "summary": "Python’da toplama, çıkarma, çarpma ve bölme işlemlerini doğrudan sayılar ve değişkenler üzerinde kullanabilirsin.",
      "levelLabel": "Beginner Learning",
      "mode": "code",
      "task": {
        "title": "Bir sepetin ara toplamını hesapla",
        "instructions": [
          "defter_fiyati değişkenine 45 değerini ata.",
          "kalem_fiyati değişkenine 15 değerini ata.",
          "İki defter ve üç kalemin toplamını ara_toplam değişkeninde hesapla.",
          "Sonucu belirtilen biçimde ekrana yazdır."
        ],
        "requirements": [
          "+ ve * operatörleri kullanılmalı.",
          "ara_toplam değişkeni tanımlanmalı.",
          "Sonuç 135 TL olmalı."
        ],
        "sampleOutput": "Ara toplam: 135 TL",
        "stdinEnabled": false,
        "stdinPlaceholder": "Bu görev dışarıdan girdi istemiyor.",
        "defaultStdin": ""
      },
      "editor": {
        "filename": "main.py",
        "starterCode": "# Sepet ara toplamını hesapla\n\ndefter_fiyati = 45\nkalem_fiyati = 15\n\nara_toplam = 0\n\nprint(f\"Ara toplam: {ara_toplam} TL\")"
      },
      "hints": [
        {
          "title": "Önce ürün toplamlarını bul",
          "body": "İki defter için defter_fiyati * 2, üç kalem için kalem_fiyati * 3 yazabilirsin."
        },
        {
          "title": "Sonuçları topla",
          "body": "İki çarpma işlemini + operatörüyle birleştir."
        },
        {
          "title": "Tam ifade",
          "body": "ara_toplam = defter_fiyati * 2 + kalem_fiyati * 3"
        }
      ],
      "validation": {
        "id": "beginner.operators.arithmetic",
        "title": "Bir sepetin ara toplamını hesapla",
        "xpReward": 40,
        "timeoutMs": 4000,
        "checks": [
