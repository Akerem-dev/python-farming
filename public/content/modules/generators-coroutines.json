      "task": {
        "title": "Kontrollü sayaç coroutine’ini tamamla",
        "instructions": [
          "sayac() generator fonksiyonunu tamamla.",
          "ValueError throw edildiğinde sayacı sıfırla ve yeni değeri yield et.",
          "GeneratorExit sırasında cleanup satırını yazdır ve hatayı yeniden yükselt.",
          "Normal send değerlerini sayaca ekle."
        ],
        "requirements": [
          "throw(ValueError) kontrollü yakalanmalı.",
          "GeneratorExit yutulmamalı.",
          "close() sonrası generator kapalı olmalı."
        ],
        "sampleOutput": "0\n5\n0\nKapatıldı",
        "stdinEnabled": false,
        "stdinPlaceholder": "Bu görev girdi istemiyor.",
        "defaultStdin": ""
      },
      "editor": {
        "filename": "main.py",
        "starterCode": "def sayac():\n    toplam = 0\n    try:\n        while True:\n            try:\n                deger = yield toplam\n                toplam += deger\n            except ValueError:\n                # sayacı sıfırla\n                pass\n    except GeneratorExit:\n        print(\"Kapatıldı\")\n        # kapanışı tamamla\n\n\nakis = sayac()\nprint(next(akis))\nprint(akis.send(5))\nprint(akis.throw(ValueError(\"sıfırla\")))\nakis.close()"
      },
