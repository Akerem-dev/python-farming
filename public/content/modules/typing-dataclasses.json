    {
      "id": "intermediate.typing.protocol",
      "moduleId": "typing-dataclasses",
      "order": 6,
      "title": "Protocol ile yapısal sözleşme",
      "summary": "Protocol, ortak davranışı kalıtım zorunluluğu olmadan type checker’a tanıtır.",
      "levelLabel": "Intermediate Learning",
      "mode": "code",
      "task": {
        "title": "Toplanabilir protocol ve iki uyumlu model oluştur",
        "instructions": [
          "Toplanabilir sınıfını Protocol tabanından türet ve runtime_checkable yap.",
          "toplam() metodunun dönüş tipini float olarak belirt.",
          "Urun ve Hizmet modellerini dataclass olarak tanımlayıp genel_toplam akışını tamamla."
        ],
        "requirements": [
          "Protocol toplam() sözleşmesini içermeli.",
          "Urun ve Hizmet protocol’dan kalıtım almadan aynı metodu sağlamalı.",
          "genel_toplam ve fatura_ozeti tamamen tiplendirilmiş olmalı."
        ],
        "sampleOutput": "270.0",
        "stdinEnabled": false,
        "stdinPlaceholder": "Bu görev dışarıdan girdi istemiyor.",
        "defaultStdin": ""
      },
      "editor": {
        "filename": "main.py",
        "starterCode": "from dataclasses import dataclass\nfrom typing import Protocol, runtime_checkable\n\n\n# Toplanabilir protocol'unu burada tanımla.\n\n\n@dataclass\nclass Urun:\n    ad: str\n    fiyat: float\n    adet: int = 1\n\n    def toplam(self) -> float:\n        return self.fiyat * self.adet\n\n\n@dataclass\nclass Hizmet:\n    ad: str\n    saat: float\n    saatlik_ucret: float\n\n    def toplam(self) -> float:\n        return self.saat * self.saatlik_ucret\n\n\ndef genel_toplam(kalemler):\n    return sum(kalem.toplam() for kalem in kalemler)\n\n\ndef fatura_ozeti(veriler):\n    kalemler = []\n    for veri in veriler:\n        if veri[\"tur\"] == \"urun\":\n            kalemler.append(Urun(veri[\"ad\"], veri[\"fiyat\"], veri.get(\"adet\", 1)))\n        else:\n            kalemler.append(Hizmet(veri[\"ad\"], veri[\"saat\"], veri[\"saatlik_ucret\"]))\n    return genel_toplam(kalemler)\n\n\nornek = [\n    {\"tur\": \"urun\", \"ad\": \"Defter\", \"fiyat\": 45.0, \"adet\": 2},\n    {\"tur\": \"hizmet\", \"ad\": \"Kurulum\", \"saat\": 2.0, \"saatlik_ucret\": 90.0},\n]\nprint(fatura_ozeti(ornek))\n"
      },
      "hints": [
        {
          "title": "Protocol gövdesi",
          "body": "class Toplanabilir(Protocol): altında toplam(self) -> float metodunu ... gövdesiyle tanımla."
        },
        {
          "title": "Runtime kontrolü",
          "body": "Sınıfın üstüne @runtime_checkable ekle."
        },
        {
          "title": "Koleksiyon tipi",
          "body": "genel_toplam parametresi list[Toplanabilir] olmalı."
        }
      ],
      "validation": {
        "id": "intermediate.typing.protocol",
        "title": "Toplanabilir protocol ve iki uyumlu model oluştur",
        "xpReward": 135,
        "timeoutMs": 5000,
