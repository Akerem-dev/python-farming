            "path": "models.py",
            "starterCode": "from dataclasses import dataclass, field\nfrom typing import Protocol\n\n\nclass Toplanabilir(Protocol):\n    def toplam(self):\n        ...\n\n\n@dataclass(frozen=True)\nclass Urun:\n    ad: str\n    birim_fiyat: float\n    adet: int = 1\n    etiketler: list[str] = field(default_factory=list)\n\n    def toplam(self):\n        return self.birim_fiyat * self.adet\n\n\n@dataclass\nclass Siparis:\n    musteri: str\n    kalemler: list[Toplanabilir] = field(default_factory=list)\n    kupon: str | None = None\n\n    def toplam(self):\n        ara_toplam = sum(kalem.toplam() for kalem in self.kalemler)\n        if self.kupon == \"PYTHON10\":\n            return round(ara_toplam * 0.90, 2)\n        return round(ara_toplam, 2)\n"
