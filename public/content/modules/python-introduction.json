    {
      "id": "beginner.introduction.first-output",
      "moduleId": "python-introduction",
      "order": 1,
      "title": "İlk Python çıktın",
      "summary": "print() fonksiyonu, bir metni veya değeri terminalde göstermek için kullanılır.",
      "levelLabel": "Beginner Learning",
      "task": {
        "title": "Ekrana ilk mesajını yazdır",
        "instructions": [
          "print() fonksiyonunun içine \"Merhaba, Python Farming!\" metnini yaz.",
          "Metnin tırnak içinde olduğundan emin ol.",
          "Kodu çalıştır ve terminal çıktısını kontrol et."
        ],
        "requirements": [
          "print() tam bir kez kullanılmalı.",
          "Mesaj tek satırda yazdırılmalı.",
          "Çıktı büyük-küçük harf ve noktalama işaretleriyle aynı olmalı."
        ],
        "sampleOutput": "Merhaba, Python Farming!",
        "stdinEnabled": false,
        "stdinPlaceholder": "Bu görev dışarıdan girdi istemiyor.",
        "defaultStdin": ""
      },
      "editor": {
        "filename": "main.py",
        "starterCode": "# İlk Python programın\n\nprint(\"\")"
      },
      "hints": [
        {
          "title": "Metinler tırnak içine yazılır",
          "body": "print(\"Merhaba, Python Farming!\") biçiminde çift tırnak kullanabilirsin."
        },
        {
          "title": "Parantezleri kapat",
          "body": "print ile açtığın parantezin satır sonunda kapandığından emin ol."
        },
        {
          "title": "Beklenen metni birebir kullan",
          "body": "Boşluk, virgül ve ünlem işareti de testin bir parçasıdır."
        }
      ],
      "validation": {
        "id": "beginner.introduction.first-output",
        "title": "Ekrana ilk mesajını yazdır",
        "xpReward": 25,
        "timeoutMs": 4000,
        "checks": [
          {
            "id": "print-once",
            "kind": "call_count",
            "name": "print",
            "min": 1,
            "max": 1,
            "label": "print() bir kez kullanıldı",
            "visibility": "visible"
          },
          {
            "id": "expected-output",
            "kind": "stdout_regex",
            "pattern": "\\AMerhaba,\\s+Python\\s+Farming!\\s*\\Z",
            "flags": "",
            "label": "Gizli test 1",
            "visibility": "hidden"
          }
        ]
      }
    },
