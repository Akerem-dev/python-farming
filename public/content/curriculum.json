      "levelLabel": "Beginner Learning",
      "task": {
        "title": "Kendini tanıtan iki değişken oluştur",
        "instructions": [
          "ad değişkenine kendi adını ata.",
          "yas değişkenine yaşını ata.",
          "İki değeri tek bir cümlede ekrana yazdır."
        ],
        "requirements": [
          "ad ve yas değişkenleri tanımlanmalı.",
          "print() kullanılmalı.",
          "Beklenen çıktı biçimi korunmalı."
        ],
        "sampleOutput": "Merhaba, ben Ali ve 20 yaşındayım.",
        "stdinEnabled": false,
        "stdinPlaceholder": "Bu görev dışarıdan girdi istemiyor.",
        "defaultStdin": ""
      },
      "editor": {
        "filename": "main.py",
        "starterCode": "# Kendini tanıtan iki değişken oluştur\n\nad = \"\"\nyas = 0\n\nprint(f\"Merhaba, ben {ad} ve {yas} yaşındayım.\")"
      },
      "hints": [
        {
          "title": "Metin değerleri tırnak içine yazılır",
          "body": "ad değişkenine değer verirken çift veya tek tırnak kullan."
        },
        {
          "title": "Yaş sayısal olmalı",
          "body": "yas değişkenine tırnaksız, sıfırdan büyük bir tam sayı ata."
        },
        {
          "title": "f-string kullanabilirsin",
          "body": "print(f\"Merhaba, ben {ad} ve {yas} yaşındayım.\") biçimi değişkenleri metne yerleştirir."
